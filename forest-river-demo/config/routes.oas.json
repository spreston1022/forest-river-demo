{
  "openapi": "3.1.0",
  "info": {
    "title": "Forest River API",
    "version": "1.0.0",
    "description": "Forest River demo API gateway"
  },
  "paths": {
    "/path-1": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "summary": "Echo endpoint",
        "description": "Forwards to echo.zuplo.io — requires a valid API key.",
        "operationId": "get-path-1",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://echo.zuplo.io"
            }
          },
          "policies": {
            "inbound": ["api-key-inbound"]
          }
        },
        "responses": {
          "200": { "description": "Successful response from echo service" },
          "401": { "description": "Unauthorized — missing or invalid API key" }
        }
      }
    },
    "/openapi": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "summary": "OpenAPI Specification",
        "operationId": "get-openapi",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "openApiSpecHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "openApiFilePath": "./config/routes.oas.json"
            }
          },
          "policies": {
            "inbound": []
          }
        },
        "responses": {
          "200": { "description": "OpenAPI specification" }
        }
      }
    }
  }
}
